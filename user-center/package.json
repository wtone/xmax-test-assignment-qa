{
    "name": "xmax-user-center-service",
    "version": "1.0.0",
    "description": "XMAX User Center Service - Handle user registration, login, and permission management",
    "main": "app.js",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "node ./bin/boot.js",
        "start": "node ./bin/boot.js",
        "cover": "npx nyc ava",
        "test": "npx ava --verbose && exit 0",
        "test:api": "npx ava test/user-center-business-flow.test.js --verbose",
        "lint": "eslint bin middlewares src test utils",
        "format": "prettier --write '*/*.js' '*/!(node_modules)/**/*.js'"
    },
    "keywords": [
        "user",
        "authentication",
        "jwt",
        "rbac",
        "microservice"
    ],
    "author": "XMAX Team",
    "license": "ISC",
