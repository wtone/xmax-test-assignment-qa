        "ioredis": "^5.4.1",
        "jsonwebtoken": "^9.0.2",
        "koa": "^2.14.2",
        "koa-bodyparser": "^4.4.1",
        "koa-bouncer": "^6.0.4",
        "koa-router": "^12.0.1",
        "koa-static": "^5.0.0",
        "koa2-cors": "^2.0.6",
        "koa2-swagger-ui": "^5.10.0",
        "lodash": "^4.17.21",
